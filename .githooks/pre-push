#!/bin/sh
# pre-push — garde-fou anti-fuite.
#
# Bloque le push si les commits à pousser introduisent un identifiant
# réel (compte Instagram/Strava, nom, user id) ou un marqueur de secret.
# Un repo d'outil ne doit contenir que des placeholders (your_account,
# example_user). Vérifie uniquement les lignes AJOUTÉES par ce push, pas
# l'historique déjà en place.
#
# Activation (une fois par clone) :  git config core.hooksPath .githooks
# Contournement exceptionnel        :  git push --no-verify

# Identifiants réels à ne jamais committer dans ce repo + marqueurs de secret.
PATTERNS='example_user|paul\.reference|example-trip|example_user|m[ée]tayer|1111111111|BEGIN [A-Z ]*PRIVATE KEY|Surface37120'

ZERO='0000000000000000000000000000000000000000'
fail=0

while read -r _local_ref local_sha _remote_ref remote_sha; do
  # Suppression de branche → rien à scanner.
  [ "$local_sha" = "$ZERO" ] && continue

  if [ "$remote_sha" = "$ZERO" ]; then
    # Nouvelle branche : on diff contre la branche principale du remote.
    base=$(git rev-parse --quiet --verify origin/main \
      || git rev-parse --quiet --verify origin/master \
      || echo "")
    if [ -n "$base" ]; then range="${base}..${local_sha}"; else range="$local_sha"; fi
  else
    range="${remote_sha}..${local_sha}"
  fi

  # Lignes ajoutées (^+, hors en-tête +++) qui matchent un motif interdit.
  # `.githooks/` est exclu : le hook lui-même contient la denylist.
  hits=$(git diff "$range" -- . ':!.githooks' 2>/dev/null \
    | grep -E '^\+' | grep -vE '^\+\+\+' \
    | grep -inE "$PATTERNS" || true)

  if [ -n "$hits" ]; then
    echo "" >&2
    echo "✗ pre-push BLOQUÉ — identifiant réel ou secret dans les commits à pousser :" >&2
    echo "$hits" | head -10 | sed 's/^/   /' >&2
    echo "" >&2
    echo "→ Remplace par un placeholder (your_account, example_user) avant de pousser." >&2
    echo "  Contournement exceptionnel et assumé : git push --no-verify" >&2
    echo "" >&2
    fail=1
  fi
done

exit $fail
