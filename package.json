{
  "name": "instagram-scraper-monorepo",
  "private": true,
  "version": "0.2.0",
  "description": "TypeScript Instagram HTML scraper. Profiles, posts, reels, stories — anti-bot-aware via Playwright persistent context. Built on the patterns of @atelier/strava-scraper.",
  "license": "MIT",
  "author": "Samuel Muselet <sam.muselet@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/ateliersam86/instagram-scraper.git"
  },
  "type": "module",
  "workspaces": ["packages/*"],
  "scripts": {
    "build": "bun run --filter '*' build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.json && bun run --filter '*' typecheck",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/bun": "^1.1.14",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  },
  "engines": {
    "bun": ">=1.1.0"
  }
}
